---
import { Instagram, Facebook } from "lucide-astro";
---

<footer class="site-footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <h3>Hver betaling tæller</h3>
      <p>Sammen skaber vi en grønnere fremtid.</p>
    </div>

    <div class="footer-column">
      <h4>Om Dankort</h4>

      <a href="#">Om os</a>
      <a href="#">Bæredygtig handel</a>
      <a href="#">Vores impact</a>
      <a href="#">Nyheder</a>
    </div>

    <div class="footer-column">
      <h4>For virksomheder</h4>

      <a href="#">Bæredygtige løsninger</a>
      <a href="#">Samarbejde</a>
      <a href="#">Ressourcer</a>
      <a href="#">Kontakt erhverv</a>
    </div>

    <div class="footer-column">
      <h4>Support</h4>

      <a href="#">Hjælp & FAQ</a>
      <a href="#">Sikkerhed</a>
    </div>

    <div class="footer-column">
      <h4>Følg med</h4>

      <div class="socials">
        <a href="#">
          <Instagram size={18} />
        </a>

        <a href="#">
          <Facebook size={18} />
        </a>
      </div>

      <p>
        Tak, fordi du er med
        <br />
        til at gøre en forskel
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-inner">
      <div class="footer-links">
        <a href="#">Privatpolitik</a>
        <a href="#">Cookiepolitik</a>
      </div>

      <span>Dansk ▾</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    background-color: var(--cream);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr 1fr 1fr;
    gap: 40px;
    padding: 48px 0;
    border-top: 1px solid var(--border);
  }

  .footer-brand h3 {
    font-size: 24px;
    margin-bottom: 12px;
  }

  .footer-brand p {
    font-size: 14px;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-left: 1px solid var(--border);
    padding-left: 28px;
  }

  .footer-column h4 {
    font-size: 15px;
    margin-bottom: 8px;
    color: var(--text-dark);
  }

  .footer-column a,
  .footer-column p {
    font-size: 14px;
    line-height: 1.5;
  }

  .socials {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }

  .socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background-color: var(--green-soft);
    color: var(--green-dark);
    transition: 0.3s ease;
  }

  .socials a:hover {
    background-color: var(--green-dark);
    color: white;
  }

  .footer-bottom {
    background-color: var(--footer-green);
    padding: 18px 0;
    margin-top: 24px;
  }

  .bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    gap: 32px;
  }
</style>