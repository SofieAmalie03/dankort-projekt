---
import { Instagram, Facebook } from "lucide-astro";
---

<footer class="site-footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <h3>Hver betaling tæller</h3>
      <p>Sammen skaber vi en grønnere fremtid.</p>
    </div>

    <div class="footer-column">
      <h4>Om Dankort</h4>

      <a href="#">Om os</a>
      <a href="#">Bæredygtig handel</a>
      <a href="#">Vores impact</a>
      <a href="#">Nyheder</a>
    </div>

    <div class="footer-column">
      <h4>For virksomheder</h4>

      <a href="#">Bæredygtige løsninger</a>
      <a href="#">Samarbejde</a>
      <a href="#">Ressourcer</a>
      <a href="#">Kontakt erhverv</a>
    </div>

    <div class="footer-column">
      <h4>Support</h4>

      <a href="#">Hjælp & FAQ</a>
      <a href="#">Sikkerhed</a>
    </div>

    <div class="footer-column">
      <h4>Følg med</h4>

      <div class="socials">
        <a
          href="https://www.instagram.com/mmdoremerket/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Besøg os på Instagram"
        >
          <Instagram size={18} />
        </a>

        <a href="#" aria-label="Besøg os på Facebook">
          <Facebook size={18} />
        </a>
      </div>

      <p>
        Tak, fordi du er med
        <br />
        til at gøre en forskel
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-inner">
      <div class="footer-links">
        <a href="#">Privatpolitik</a>
        <a href="#">Cookiepolitik</a>
      </div>

      <span>Dansk ▾</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    background-color: var(--cream);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr 1fr 1fr;
    gap: 40px;
    padding: 48px 0 64px;
    border-top: 1px solid var(--border);
  }

  .footer-brand h3 {
    font-size: 24px;
    margin-bottom: 12px;
    color: var(--green-dark);
  }

  .footer-brand p {
    font-size: 14px;
    color: var(--text);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-left: 1px solid var(--border);
    padding-left: 28px;
  }

  .footer-column h4 {
    font-size: 15px;
    margin-bottom: 8px;
    color: var(--text-dark);
  }

  .footer-column a,
  .footer-column p {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text);
    text-decoration: none;
  }

  .footer-column a:hover {
    text-decoration: underline;
  }

  .socials {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }

  .socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background-color: var(--green-soft);
    color: var(--green-dark);
    transition: 0.3s ease;
  }

  .socials a:hover {
    background-color: var(--green-dark);
    color: white;
  }

  .footer-bottom {
    background-color: var(--footer-green);
    padding: 18px 0;
  }

  .bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    gap: 32px;
  }

  .footer-links a {
    color: white;
    text-decoration: none;
    font-size: 13px;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .bottom-inner span {
    color: white;
    font-size: 13px;
  }

  @media (max-width: 700px) {
    .site-footer {
      margin-top: 0;
    }

    .footer-top {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      padding: 13px 20px 14px;
      border-top: 1px solid var(--border);
      background-color: var(--cream);
    }

    .footer-brand h3 {
      font-size: 8px;
      font-family: Arial, Helvetica, sans-serif;
      margin-bottom: 3px;
    }

    .footer-brand p {
      font-size: 6px;
      line-height: 1.25;
    }

    .footer-column {
      gap: 3px;
      border-left: 1px solid var(--border);
      padding-left: 8px;
    }

    .footer-column h4 {
      font-size: 6.5px;
      margin-bottom: 2px;
    }

    .footer-column a,
    .footer-column p {
      font-size: 5.7px;
      line-height: 1.35;
    }

    .socials {
      gap: 4px;
      margin-bottom: 3px;
    }

    .socials a {
      width: 13px;
      height: 13px;
    }

    .socials svg {
      width: 8px;
      height: 8px;
    }

    .footer-bottom {
      padding: 7px 20px;
    }

    .bottom-inner {
      width: 100%;
      font-size: 6px;
    }

    .footer-links {
      gap: 17px;
    }

    .footer-links a,
    .bottom-inner span {
      font-size: 6px;
    }
  }
</style>