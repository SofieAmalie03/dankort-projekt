---
const { label, number, unit } = Astro.props;
---

<div class="stat-card">
  <p>{label}</p>
  <h3>{number}</h3>
  <span>{unit}</span>
</div>

<style>
  .stat-card {
    background-color: #182845;
    color: white;
    padding: 24px;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .stat-card p {
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .stat-card h3 {
    color: white;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 32px;
    margin-bottom: 4px;
  }

  .stat-card span {
    font-size: 14px;
  }
</style>