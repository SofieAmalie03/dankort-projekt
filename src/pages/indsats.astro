---
import Layout from "../layouts/Layout.astro";
import "../styles/indsats.css";
---

<Layout title="Indsats">

<!-- første seksjon kontooversikt -->
 <section class="container indsats-hero">
  <h1>Kontooversigt</h1>
  <div class="konto-grid">

    <!--kortbilde -->
    <div class="konto-card-img">
      <img src="/public/dk-kort 1.webp" alt="Dankort">
    </div>

    <!--stats-bokser -->
    <div class="konto-stats">
      <div class="stat-box">
        <span class="stat-label">Dit bidrag - Areal sikret</span>
        <p class="stat-nummer">24 465</p>
        <p class="stat-unit">m2</p>
      </div>
      <div class="stat-box">
        <span class="stat-label">Dit bidrag</span>
        <p class="stat-nummer">245</p>
        <p class="stat-unit">kr i total</p>
      </div>
      <div class="stat-box">
        <span class="stat-label">København - Areal sikret</span>
        <p class="stat-nummer">1 478 930</p>
        <p class="stat-unit">m2</p>
      </div>
      <div class="stat-box">
        <span class="stat-label">Per indbygger</span>
        <p class="stat-nummer">87</p>
        <p class="stat-unit">m2 / person</p>
      </div>
  </div>
 </section>


 <!--andre seksjon transaksjoner og kart -->
 <section class="container indsats-section2">
  <div class="transaksjoner-box">
    <h2>Sidste transaktioner</h2>
    <div class="transaksjon-rad">
    <span class="trans-ikon">💳</span>
    <div class="trans-info">
      <p class="trans-navn">Dankort</p>
      <p class="trans-navn">29 jan</p>
    </div>
    <p class="trans-belop">-330kr</p>
    </div>
    <div class="transaksjon-rad">
      <span class="trans-ikon">💳</span>
      <div class="trans-info">
        <p class="trans-navn">Dankort</p>
        <p class="trans-navn">29 jan</p>
      </div>
      <p class="trans-belop">-200kr</p>
    </div>
    <div class="transaksjon-rad">
      <span class="trans-ikon">💳</span>
      <div class="trans-info">
        <p class="trans-navn">Dankort</p>
        <p class="trans-navn">15 jan</p>
      </div>
      <p class="trans-belop">-115kr</p>
    </div>
    <button class="btn-rapport">📊 Se den detaljeret rapport</button>
  </div>

  <!--din by -->
  <div class="dinby-box">
    <h2>Din by - København</h2>
    <div class="kart-placeholder">
      <img src="/public/københavnby.webp" alt="københavnby">
    </div>
    <div class="dinby-stat">
      <div>
        <p class="dinby-label">Totalt sikret areal</p>
        <p class="dinby-nummer">1 478 930 m2</p>
      </div>
      <div>
        <p class="dinby-label">Per indbygger</p>
        <p class="dinby-nummer">87 m2</p>
      </div>
    </div>
  </div>
 </section>

 <!-- seksjon 3 dine valg -->
<section class="container indsats-section3">
  <div class="valg-box">

    <!-- venstre -->
    <div class="valg-venstre">
      <h2>Dine valg betaler sig</h2>
      <p class="reward-label">Reward points</p>
      <p class="reward-tall">5 000</p>
      <div class="points-tabell">
        <div class="points-kolonne">
          <p class="points-header">Points</p>
          <p>200</p>
          <p>150</p>
          <p>50</p>
        </div>
        <div class="points-kolonne">
          <p class="points-header">Points</p>
          <p>5</p>
          <p>500</p>
          <p>1000</p>
        </div>
      </div>
    </div>

    <!-- høyre -->
    <div class="valg-høyre">
      <div class="org-rad">
        <img src="/dn1.webp" alt="ikon" class="org-ikon" />
        <p>Lagkagehuset</p>
      </div>
      <div class="org-rad">
        <img src="/dn2.webp" alt="ikon" class="org-ikon" />
        <p>Hart</p>
      </div>
      <div class="org-rad">
        <img src="/dn3.webp" alt="ikon" class="org-ikon" />
        <p>Magasin</p>
      </div>
    </div>
   <div class="valg-knapp-wrapper">
    <button class="btn-kupong" id="aapneKupong">Scan kupong</button>
   </div>
  </div>
</section>

<!-- POPUP -->
<div class="popup-overlay" id="popupOverlay">
  <div class="popup-innhold">
    <button class="popup-lukk" id="lukkKupong">✕</button>
    <img src="/kupong.webp" alt="Kupong" />
  </div>
</div>

<!-- seksjons fire -->
<section class="container indsats-section4">
  <div class="redde-box">
    <p class="redde-label">Du er med til at redde</p>
    <p class="redde-undertittel">Dele af dansk natur</p>
    <div class="redde-innhold">
      <video class="redde-bilde" autoplay muted loop playsinline>
        <source src="/video.mp4" type="video/mp4" />
      </video>
      <div class="redde-stats">
        <div class="redde-stat-rad">
          <div class="redde-strek"></div>
          <div>
            <p class="redde-tall">83.000</p>
            <p class="redde-enhet">m2 sikret areal</p>
          </div>
        </div>
        <div class="redde-stat-rad">
          <div class="redde-strek"></div>
          <div>
            <p class="redde-tall">4</p>
            <p class="redde-enhet">aktive projekter</p>
          </div>
        </div>
        <div class="redde-stat-rad">
          <div class="redde-strek"></div>
          <div>
            <p class="redde-tall">12</p>
            <p class="redde-enhet">bidrag i år</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
 
<script>
  const aapneKupong = document.getElementById("aapneKupong");
  const lukkKupong = document.getElementById("lukkKupong");
  const popupOverlay = document.getElementById("popupOverlay");

  aapneKupong.addEventListener("click", () => {
    popupOverlay.classList.add("aktiv");
  });

  lukkKupong.addEventListener("click", () => {
    popupOverlay.classList.remove("aktiv");
  });

  popupOverlay.addEventListener("click", (e) => {
    if (e.target === popupOverlay) {
      popupOverlay.classList.remove("aktiv");
    }
  });
</script>
 </Layout>