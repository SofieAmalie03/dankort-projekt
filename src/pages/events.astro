---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import EventCard from "../components/EventCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getEvents } from "../lib/supabase.js";
import "../styles/events.css";

type Event = {
  id: number;
  city: string;
  title: string;
  category: string;
  category_label: string;
  text: string;
  date: string;
  display_date: string;
  time: string;
  location: string;
  image: string;
};

const events = (await getEvents()) as Event[];

const today = new Date().toISOString().split("T")[0];

const upcomingEvents = events.filter((event: Event) => event.date >= today);

const featuredEvent = upcomingEvents[0];

const visibleEvents = featuredEvent
  ? upcomingEvents.filter((event: Event) => event.id !== featuredEvent.id)
  : upcomingEvents;
---

<Layout title="Events">
  <section class="events-hero container">
    <div class="events-hero-text">
      <h1>Mere end bare betaling.</h1>

      <p>
        Oplev events, kaffe, fællesskab og gode øjeblikke rundt i Danmark —
        samlet ét sted med Dankort.
      </p>

      <div class="hero-buttons">
        <Button href="#events-list">Kommende events ↓</Button>
        <Button href="#" variant="light">Hvad er Dankort Øremærket?</Button>
      </div>
    </div>

    <div class="events-hero-image">
      <img src="/event 1.webp" alt="Dankort event" />
    </div>
  </section>

<section class="container event-filters">
  <button class="filter-btn active" data-filter="all">Alle events</button>
  <button class="filter-btn" data-filter="kaffe">Kaffe & community</button>
  <button class="filter-btn" data-filter="popups">Pop-ups</button>
  <button class="filter-btn" data-filter="live">Live events</button>
  <button class="filter-btn" data-filter="workshops">Workshops</button>
  <button class="filter-btn" data-filter="walkclubs">Walk clubs</button>
</section>

  <section id="events-list" class="container events-layout">
    <div class="events-left">
      <div class="section-heading">
        <h2>Kommende events</h2>
        <a href="#">Se kalender</a>
      </div>

      <div class="events-list">
        {
          visibleEvents.map((event: Event) => (
            <div class="event-item" data-category={event.category}>
              <EventCard
                city={event.city}
                title={event.title}
                text={event.text}
                date={event.display_date}
                time={event.time}
                location={event.location}
                image={event.image}
              />
            </div>
          ))
        }
      </div>

      <button class="load-more" type="button">Se flere events ↓</button>
    </div>

    <aside class="events-right">
      {featuredEvent && (
        <div class="featured-event">
          <img src={featuredEvent.image} alt={featuredEvent.title} />

          <div class="featured-content">
            <span>{featuredEvent.city}</span>
            <h2>DET SKER SNART</h2>
            <h3>{featuredEvent.title}</h3>

            <p>{featuredEvent.text}</p>

            <div class="featured-info">
              <p>{featuredEvent.display_date}</p>
              <p>{featuredEvent.time}</p>
              <p>{featuredEvent.location}</p>
            </div>
          </div>
        </div>
      )}

      <div class="event-map">
        <h3>Find events nær dig</h3>

        <div class="map-box">
          <button class="map-pin pin-aalborg">5 <span>Aalborg</span></button>
          <button class="map-pin pin-aarhus">8 <span>Aarhus</span></button>
          <button class="map-pin pin-esbjerg">3 <span>Esbjerg</span></button>
          <button class="map-pin pin-odense">7 <span>Odense</span></button>
          <button class="map-pin pin-kbh">11 <span>KBH</span></button>
        </div>

        <button class="map-btn">Se alle på kortet</button>
      </div>

      <div class="instagram-box">
        <h3>Seneste fra Instagram</h3>
        <p>@mitdankort</p>

        <div class="instagram-grid">
          <img src="/event 1.webp" alt="Instagram billede" />
          <img src="/event 1.webp" alt="Instagram billede" />
          <img src="/event 1.webp" alt="Instagram billede" />
          <img src="/event 1.webp" alt="Instagram billede" />
        </div>
      </div>

      <div class="small-impact-box">
        <h3>Små valg. Stærkere fællesskab.</h3>
        <p>
          Når du betaler med Dankort, er du med til at holde mere værdi i
          Danmark.
        </p>
      </div>
    </aside>
  </section>

    <Newsletter />

  <script>
    import "../scripts/events.js";
  </script>
</Layout>