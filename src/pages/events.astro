---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import EventCard from "../components/EventCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getEvents } from "../lib/supabase.js";
import EventMap from "../components/EventMap.astro";
import "../styles/events.css";

type Event = {
  id: number;
  city: string;
  title: string;
  category: string;
  category_label: string;
  text: string;
  date: string;
  display_date: string;
  time: string;
  location: string;
  image: string;
};

const events = (await getEvents()) as Event[];

const today = new Date().toISOString().split("T")[0];

const upcomingEvents = events.filter((event: Event) => event.date >= today);

const featuredEvent = upcomingEvents[0];

const visibleEvents = featuredEvent
  ? upcomingEvents.filter((event: Event) => event.id !== featuredEvent.id)
  : upcomingEvents;
---

<Layout title="Events">
  <section class="events-hero container">
    <div class="events-hero-text">
      <h1>Mere end bare betaling.</h1>

      <p>
        Oplev events, kaffe, fællesskab og gode øjeblikke rundt i Danmark —
        samlet ét sted med Dankort.
      </p>

      <div class="hero-buttons">
        <Button href="#events-list">Kommende events →</Button>
       <Button href="/projekter" variant="light">Hvad er Dankort Øremærket?</Button>
      </div>
    </div>

    <div class="events-hero-image">
      <img src="/eventhero.webp" alt="Dankort event" />
    </div>
  </section>

  <section class="container event-filters">
    <button class="filter-btn active" data-filter="all">Alle events</button>
    <button class="filter-btn" data-filter="kaffe">Sortér efter</button>
    <button class="filter-btn filter-extra" data-filter="popups">Pop-ups</button>
    <button class="filter-btn filter-extra" data-filter="live">Live events</button>
    <button class="filter-btn filter-extra" data-filter="workshops">Workshops</button>
    <button class="filter-btn filter-extra" data-filter="walkclubs">Walk clubs</button>
  </section>

  <section id="events-list" class="container events-layout">
    <div class="events-left">
      <div class="section-heading">
        <h2>Kommende events</h2>
        <a href="#">Se kalender →</a>
      </div>

      <div class="events-list">
        {
          visibleEvents.map((event: Event) => (
            <div class="event-item" data-category={event.category}>
              <EventCard
                city={event.city}
                title={event.title}
                text={event.text}
                date={event.display_date}
                time={event.time}
                location={event.location}
                image={event.image}
              />
            </div>
          ))
        }
      </div>

      <button class="load-more" type="button">Se flere events ↓</button>
    </div>

    <aside class="events-right">
      {
        featuredEvent && (
          <div class="featured-event">
            <img src={featuredEvent.image} alt={featuredEvent.title} />

            <div class="featured-content">
              <p class="featured-label">DET SKER SNART</p>

              <div class="featured-text-group">
                <span>{featuredEvent.city}</span>
                <h3>{featuredEvent.title}</h3>

                <p class="featured-text">{featuredEvent.text}</p>

                <div class="featured-info">
                  <p>{featuredEvent.display_date}</p>
                  <p>{featuredEvent.time}</p>
                  <p>{featuredEvent.location}</p>
                </div>
              </div>

              <a href="#" class="featured-arrow" aria-label="Læs mere om event">
                →
              </a>
            </div>
          </div>
        )
      }

      <EventMap events={upcomingEvents} />

      <div class="small-impact-box">
        <div class="small-impact-icon">
          <img src="/treeicon.webp" alt="Ikon af træ" />
        </div>

        <div class="small-impact-content">
          <h3>Små valg. Stærkere fællesskab.</h3>
          <p>
            Når du betaler med Dankort, er du med til at holde mere værdi i
            Danmark — helt uden ekstra besvær.
          </p>
        </div>

        <a href="#" class="small-impact-arrow" aria-label="Læs mere">
          →
        </a>
      </div>

      <div class="instagram-box">
        <div class="instagram-heading">
          <h3>Se seneste fra Instagram</h3>

          <a
            href="https://www.instagram.com/mmdoremerket/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Se mere →
          </a>
        </div>

        <a
          href="https://www.instagram.com/mmdoremerket/"
          target="_blank"
          rel="noopener noreferrer"
          class="instagram-name"
        >
          @mmdoremerket
        </a>

        <div class="instagram-grid">
          <a
            href="https://www.instagram.com/p/DY2AjTZtEh_zMlBIYRDkPDgvElA0S2ktKFnD9k0/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src="/insta1.webp" alt="Instagram billede" />
          </a>

          <a
            href="https://www.instagram.com/p/DYzXk6QNakB5kRBGEUWjorzri08Fj-nl22svls0/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src="/insta2.webp" alt="Instagram billede" />
          </a>

          <a
            href="https://www.instagram.com/p/DY1iRm2jVxLBCCT8tFuj4m_EAyedx59FPpib8s0/?img_index=1"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src="/insta3.webp" alt="Instagram billede" />
          </a>

          <a
            href="https://www.instagram.com/p/DYMd01_th8zswbZBlUNzitN9jvr-lALRs69KqI0/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src="/insta4.webp" alt="Instagram billede" />
          </a>
        </div>
      </div>
    </aside>
  </section>

  <Newsletter />

  <script>
    import "../scripts/events.js";
  </script>
</Layout>